{
  "name": "css-intellisense",
  "publisher": "asosunoff",
  "icon": "assets/icon.png",
  "displayName": "CSS IntelliSense",
  "version": "1.0.3",
  "license": "MIT",
  "engines": {
    "vscode": "^1.116.0"
  },
  "activationEvents": [
    "onLanguage:vue",
    "onLanguage:html",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact"
  ],
  "main": "./dist/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/aSosunoff/css-intellisense.git"
  },
  "scripts": {
    "compile": "tsc -p .",
    "pack": "npm run compile && vsce package",
    "publish": "vsce publish",
    "buil_assets": "npx sharp-cli -i icon.svg -o assets/icon.png resize 128 128",
    "release": "node release.mjs"
  },
  "devDependencies": {
    "@types/vscode": "^1.116.0",
    "typescript": "^6.0.3"
  }
}
