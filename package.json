{
  "name": "css-intellisense",
  "publisher": "asosunoff",
  "icon": "assets/icon.png",
  "displayName": "CSS IntelliSense",
  "version": "1.0.0",
  "license": "MIT",
  "engines": {
    "vscode": "^1.116.0"
  },
  "activationEvents": [
    "onLanguage:vue",
    "onLanguage:html",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact"
  ],
  "main": "./dist/index.js",
  "contributes": {
    "configuration": {
      "title": "CSS IntelliSense",
      "properties": {
        "cssIntellisense.classesFileName": {
          "type": "string",
          "default": "classes.json",
          "description": "Default class map file name to search for in the workspace when no explicit path is configured."
        },
        "cssIntellisense.classesFilePath": {
          "type": "string",
          "default": "",
          "description": "Path to the class map JSON file. Relative paths are resolved from the workspace root. Absolute paths are supported."
        }
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aSosunoff/css-intellisense.git"
  },
  "scripts": {
    "compile": "tsc -p .",
    "pack": "npm run compile && vsce package",
    "publish": "vsce publish",
    "build": "npx sharp-cli -i icon.svg -o assets/icon.png resize 128 128"
  },
  "devDependencies": {
    "@types/vscode": "^1.116.0",
    "typescript": "^6.0.3"
  }
}
